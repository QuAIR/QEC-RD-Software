# -----------------------------------------------------------------------------
# Python 生态（Stim / Tensor QEC / DeltaKit 均以 Python 工作流为主）
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python
*.egg-info/
*.egg
dist/
build/
eggs/
.eggs/
sdist/
wheels/pip-wheel-metadata/
MANIFEST

# 虚拟环境与工具链
.venv/
venv/
ENV/
env/

# -----------------------------------------------------------------------------
# Stim：高速 stabilizer / DEM / 采样；常见为预编译轮子，也可能本地编译扩展
# -----------------------------------------------------------------------------
*.pyd
*.so
*.dylib
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
compile_commands.json
*.a
*.lib
*.obj
*.o

# Stim / 采样与评估产生的中大型中间结果（按需再纳入版本库）
dem_cache/
shots_cache/
sim_out/
stim_cache/

# -----------------------------------------------------------------------------
# Tensor QEC：张量网络与张量后端（PyTorch / JAX 等）；体积大、可再生成产物
# -----------------------------------------------------------------------------
*.pt
*.pth
*.ckpt
*.safetensors
wandb/
lightning_logs/

# JAX 编译与下载缓存
.jax/
tensorflow_datasets/

# -----------------------------------------------------------------------------
# DeltaKit：与控制器/脉冲/校准流水相关的典型本地配置与密钥（勿提交）
# -----------------------------------------------------------------------------
.env
.env.*
*.local.yaml
*.local.yml
secrets/
*.pem

# -----------------------------------------------------------------------------
# Jupyter / 笔记与可复现脚本常见杂项
# -----------------------------------------------------------------------------
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# 测试与覆盖率
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.ruff_cache/
.mypy_cache/

# -----------------------------------------------------------------------------
# 操作系统与编辑器
# -----------------------------------------------------------------------------
