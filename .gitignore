Thumbs.db
.idea/

# -----------------------------------------------------------------------------
# 日志与临时文件
# -----------------------------------------------------------------------------
*.log
logs/
tmp/
temp/

.cursor/*
.claude/*
.worktrees/

# Agent monitor runtime state
scripts/.monitor_state.json
